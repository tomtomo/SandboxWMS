<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <!-- .proto + codegen (Grpc.Tools build-time). GrpcServices=Both -> server base (di-implement *.Api) +
         client stub (dipakai konsumen, mis. Notification 04d recipient-detail). Grpc.Core.Api = abstraksi
         base (ClientBase/ServerCallContext); Google.Protobuf = runtime message. Keduanya SAH di *.Grpc
         (ADR-0009). Grpc.Tools PrivateAssets=all (codegen lokal, tak mengalir ke konsumen). -->
    <PackageReference Include="Grpc.Core.Api" />
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="Grpc.Tools">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Protobuf Include="Protos\auth.proto" GrpcServices="Both" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

</Project>
