<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <!-- .proto + codegen (Grpc.Tools build-time). GrpcServices=Both -> server base + client stub.
         Grpc.Core.Api = abstraksi base class (ClientBase/ServerCallContext); Google.Protobuf = runtime
         message. Keduanya SAH di *.Grpc (ADR-0009). Grpc.Tools PrivateAssets=all (codegen lokal, tak
         mengalir ke konsumen). Belum ada <Protobuf> include -> codegen no-op sampai Phase 04a Task proto. -->
    <PackageReference Include="Grpc.Core.Api" />
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="Grpc.Tools">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!-- Codegen GrpcServices=Both → server base (MasterDataReadApiBase, di-implement *.Api) +
         client stub (MasterDataReadApiClient, dipakai konsumen Inbound/Outbound). -->
    <Protobuf Include="Protos\master_data.proto" GrpcServices="Both" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

</Project>
