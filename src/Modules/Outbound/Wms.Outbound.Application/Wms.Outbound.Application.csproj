<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Wms.Outbound.Domain\Wms.Outbound.Domain.csproj" />
    <!-- Own published language: emit WaveReleased/PickingCompleted/ShipmentDispatched -->
    <ProjectReference Include="..\Wms.Outbound.Contracts\Wms.Outbound.Contracts.csproj" />
    <!-- Cross-context published language consumed (FF#3 allows *.Contracts only):
         StockAllocatedV1 (Inventory) → create PickingTask per allocation -->
    <ProjectReference Include="..\..\Inventory\Wms.Inventory.Contracts\Wms.Inventory.Contracts.csproj" />
    <ProjectReference Include="..\..\..\BuildingBlocks\Wms.BuildingBlocks.Application\Wms.BuildingBlocks.Application.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- CQRS pipeline for REST slices (CreateWave/CompletePicking/DispatchWave/ReceiveOrder).
         MediatR free OSS line; FluentValidation. -->
    <PackageReference Include="MediatR" />
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

</Project>
