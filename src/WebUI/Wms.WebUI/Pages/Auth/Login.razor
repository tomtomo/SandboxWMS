@page "/"
@implements IDisposable
@inject WmsApiClient Api
@inject TokenStore TokenStore
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ProtectedLocalStorage Storage

<PageTitle>Login</PageTitle>
<MudText Typo="Typo.h4" GutterBottom="true">Login</MudText>

@if (TokenStore.IsAuthenticated)
{
    <MudAlert Severity="Severity.Success">
        Login sebagai <b>@TokenStore.Username</b> (userId: @TokenStore.UserId).
    </MudAlert>
}
else
{
    <MudPaper Class="pa-6" Style="max-width:420px">
        <MudTextField @bind-Value="_username" Label="Username" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined"
                      InputType="InputType.Password" Class="mb-3" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                   OnClick="DoLogin" Disabled="_busy">
            @(_busy ? "..." : "Login")
        </MudButton>
    </MudPaper>
}

@code {
    private string _username = "admin";
    private string _password = string.Empty;
    private bool _busy;

    // What: subscribe perubahan TokenStore agar halaman ini re-render saat auth-state berubah.
    // Why: Logout (MainLayout) memanggil TokenStore.Clear() lalu NavigateTo("/"). Bila user SUDAH di "/"
    // (lihat alert "Login sebagai ..."), navigasi ke URL yang sama = no-op → page component tak re-render,
    // alert stale bertahan & form login tak muncul (user tak bisa re-login tanpa reload). Subscribe OnChange
    // (pola sama MainLayout) → Clear() men-trigger StateHasChanged → branch beralih ke form login.
    protected override void OnInitialized() => TokenStore.OnChange += StateHasChanged;

    public void Dispose() => TokenStore.OnChange -= StateHasChanged;

    private async Task DoLogin()
    {
        _busy = true;
        var result = await Api.Auth.LoginAsync(_username, _password);
        if (result.Success)
        {
            TokenStore.SetSession(result.Value!.AccessToken, _username, null);
            TokenStore.SetUserId(await Api.Auth.MeAsync());
            await Storage.SetAsync("wms.access", result.Value!.AccessToken);
            await Storage.SetAsync("wms.username", _username);
            await Storage.SetAsync("wms.userId", TokenStore.UserId ?? string.Empty);
        }
        _busy = false;
        if (result.Success)
        {
            Snackbar.Add("Login sukses.", Severity.Success);
            // landing netral pasca-login (Home blank) — bukan auto-buka /goods-receipts (konteks Inbound dipaksakan)
            Nav.NavigateTo("/home");
        }
        else
        {
            Snackbar.Add(result.ErrorMessage!, Severity.Error);
        }
    }
}
