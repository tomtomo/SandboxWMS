@page "/inventory/stocks"
@inject WmsApiClient Api
@inject IDialogService DialogService

<PageTitle>Stocks</PageTitle>
<PageHeader Title="Stocks" />

@if (_gapMessage is not null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">@_gapMessage</MudAlert>
}

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudSelect T="Guid?" @bind-Value="_warehouseId" Label="Warehouse" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:200px;">
            @foreach (var w in _warehouses)
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)w.WarehouseId)">@w.Name</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_sku" Label="SKU" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:200px;" />
        <MudSelect T="StockStatus?" @bind-Value="_status" Label="Status" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:180px;">
            @foreach (var s in Enum.GetValues<StockStatus>())
            {
                <MudSelectItem T="StockStatus?" Value="@((StockStatus?)s)">@s</MudSelectItem>
            }
        </MudSelect>
        <MudButton OnClick="ApplyFilter" Variant="Variant.Outlined">Apply</MudButton>
        <MudButton OnClick="ResetFilter" Variant="Variant.Text">Reset</MudButton>
    </MudStack>
</MudPaper>

<MudTable T="StockDto" ServerData="LoadAsync" Dense="true" Hover="true" Striped="true" @ref="_table">
    <HeaderContent>
        <MudTh>SKU</MudTh><MudTh>Location</MudTh><MudTh>Status</MudTh><MudTh>Batch</MudTh><MudTh>Expiry</MudTh>
        <MudTh>Qty</MudTh><MudTh>Source GR</MudTh><MudTh Style="width:90px;">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Sku</MudTd>
        <MudTd>@context.LocationId</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@StockColor(context.Status)">@context.Status</MudChip></MudTd>
        <MudTd>@(context.Batch ?? "-")</MudTd>
        <MudTd>@(context.Expiry?.ToString("yyyy-MM-dd") ?? "-")</MudTd>
        <MudTd>@context.Quantity</MudTd>
        <MudTd>@context.SourceGoodsReceiptId.ToString()[..8]</MudTd>
        <MudTd><MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" OnClick="@(() => OpenAdjust(context))">Adjust</MudButton></MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
    <NoRecordsContent><MudAlert Severity="Severity.Info" Class="ma-3">Tidak ada stock untuk filter ini.</MudAlert></NoRecordsContent>
</MudTable>

@code {
    private MudTable<StockDto>? _table;
    private Guid? _warehouseId;
    private IReadOnlyList<WarehouseDto> _warehouses = [];
    private string _sku = "";
    private StockStatus? _status;
    private string? _gapMessage;

    // muat warehouse untuk dropdown filter (gantikan free-text GUID — lookup, bukan ketik id)
    protected override async Task OnInitializedAsync()
    {
        var warehouses = await Api.MasterData.ListWarehousesAsync(1, 100, isActive: true);
        if (warehouses.Success)
            _warehouses = warehouses.Value!.Items;
    }

    private async Task<TableData<StockDto>> LoadAsync(TableState state, CancellationToken ct)
    {
        var result = await Api.Inventory.ListStocksAsync(state.Page + 1, state.PageSize,
            _warehouseId?.ToString(),
            string.IsNullOrWhiteSpace(_sku) ? null : _sku, _status, ct);
        if (!result.Success)
        {
            _gapMessage = result.ErrorMessage;
            return new TableData<StockDto> { Items = Array.Empty<StockDto>(), TotalItems = 0 };
        }
        _gapMessage = null;
        return new TableData<StockDto> { Items = result.Value!.Items, TotalItems = result.Value!.TotalCount };
    }

    private void ApplyFilter() => _table?.ReloadServerData();
    private void ResetFilter() { _warehouseId = null; _sku = ""; _status = null; _table?.ReloadServerData(); }

    private async Task OpenAdjust(StockDto stock)
    {
        var parameters = new DialogParameters { [nameof(AdjustStockDialog.Existing)] = stock };
        var dialog = await DialogService.ShowAsync<AdjustStockDialog>("Adjust Stock", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: true }) _table?.ReloadServerData();
    }

    private static Color StockColor(string s) => s switch
    {
        "Quarantine" => Color.Error, "OnHand" => Color.Info, "Available" => Color.Success,
        "Allocated" => Color.Warning, "Picked" => Color.Secondary, _ => Color.Default,
    };
}
