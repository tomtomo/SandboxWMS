@page "/outbound/waves"
@inject WmsApiClient Api
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>Waves</PageTitle>
<PageHeader Title="Waves">
    <Actions>
        <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Filled" OnClick="OpenCreate">Buat Wave</MudButton>
    </Actions>
</PageHeader>

@if (_gapMessage is not null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">@_gapMessage</MudAlert>
}

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudSelect T="WaveStatus?" @bind-Value="_status" Label="Status" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:200px;">
            @foreach (var s in Enum.GetValues<WaveStatus>())
            {
                <MudSelectItem T="WaveStatus?" Value="@((WaveStatus?)s)">@s</MudSelectItem>
            }
        </MudSelect>
        <MudButton OnClick="ApplyFilter" Variant="Variant.Outlined">Apply</MudButton>
        <MudButton OnClick="ResetFilter" Variant="Variant.Text">Reset</MudButton>
    </MudStack>
</MudPaper>

<MudTable T="WaveSummaryDto" ServerData="LoadAsync" Dense="true" Hover="true" Striped="true" @ref="_table"
          OnRowClick="@(args => { if (args.Item is not null) Nav.NavigateTo($"/outbound/waves/{args.Item.WaveId}"); })" RowStyle="cursor:pointer">
    <HeaderContent><MudTh>Wave</MudTh><MudTh>Status</MudTh><MudTh>Orders</MudTh><MudTh>Lines</MudTh></HeaderContent>
    <RowTemplate>
        <MudTd>@context.WaveId.ToString()[..8]</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@WaveColor(context.Status)">@context.Status</MudChip></MudTd>
        <MudTd>@context.OrderCount</MudTd>
        <MudTd>@context.LineCount</MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
    <NoRecordsContent><MudAlert Severity="Severity.Info" Class="ma-3">Belum ada wave.</MudAlert></NoRecordsContent>
</MudTable>

@code {
    private MudTable<WaveSummaryDto>? _table;
    private WaveStatus? _status;
    private string? _gapMessage;

    private async Task<TableData<WaveSummaryDto>> LoadAsync(TableState state, CancellationToken ct)
    {
        var result = await Api.Outbound.ListWavesAsync(state.Page + 1, state.PageSize, _status, ct);
        if (!result.Success) { _gapMessage = result.ErrorMessage; return new TableData<WaveSummaryDto> { Items = Array.Empty<WaveSummaryDto>(), TotalItems = 0 }; }
        _gapMessage = null;
        return new TableData<WaveSummaryDto> { Items = result.Value!.Items, TotalItems = result.Value!.TotalCount };
    }

    private void ApplyFilter() => _table?.ReloadServerData();
    private void ResetFilter() { _status = null; _table?.ReloadServerData(); }

    private async Task OpenCreate()
    {
        var dialog = await DialogService.ShowAsync<CreateWaveDialog>("Buat Wave");
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: true }) _table?.ReloadServerData();
    }

    private static Color WaveColor(string s) => s switch
    { "Active" => Color.Info, "Ready" => Color.Warning, "Dispatched" => Color.Success, _ => Color.Default };
}
