@page "/outbound/picking-tasks"
@inject WmsApiClient Api
@inject IDialogService DialogService
@inject TokenStore TokenStore

<PageTitle>Picking Tasks</PageTitle>
<PageHeader Title="Picking Tasks" />

@if (_gapMessage is not null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">@_gapMessage</MudAlert>
}

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_assignedTo" Label="Assigned To (userId)" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:220px;" Disabled="_onlyMine" />
        <MudSelect T="PickingTaskStatus?" @bind-Value="_status" Label="Status" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:180px;">
            @foreach (var s in Enum.GetValues<PickingTaskStatus>())
            {
                <MudSelectItem T="PickingTaskStatus?" Value="@((PickingTaskStatus?)s)">@s</MudSelectItem>
            }
        </MudSelect>
        <MudSwitch @bind-Value="_onlyMine" Label="Hanya assigned ke saya" Color="Color.Primary" T="bool" />
        <MudButton OnClick="ApplyFilter" Variant="Variant.Outlined">Apply</MudButton>
        <MudButton OnClick="ResetFilter" Variant="Variant.Text">Reset</MudButton>
    </MudStack>
</MudPaper>

<MudTable T="PickingTaskDto" ServerData="LoadAsync" Dense="true" Hover="true" Striped="true" @ref="_table">
    <HeaderContent>
        <MudTh>SKU</MudTh><MudTh>Qty</MudTh><MudTh>Batch</MudTh><MudTh>Wave</MudTh><MudTh>Assigned To</MudTh><MudTh>Status</MudTh><MudTh>Staging</MudTh><MudTh Style="width:100px;">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Sku</MudTd>
        <MudTd>@context.Qty</MudTd>
        <MudTd>@(context.Batch ?? "-")</MudTd>
        <MudTd>@context.WaveId.ToString()[..8]</MudTd>
        <MudTd>@(context.AssignedTo ?? "-")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@TaskColor(context.Status)">@context.Status</MudChip></MudTd>
        <MudTd>@(context.StagingLocationId ?? "-")</MudTd>
        <MudTd>
            @if (context.Status == nameof(PickingTaskStatus.Assigned))
            {
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenComplete(context))">Complete</MudButton>
            }
        </MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
    <NoRecordsContent><MudAlert Severity="Severity.Info" Class="ma-3">Belum ada picking task.</MudAlert></NoRecordsContent>
</MudTable>

@code {
    private MudTable<PickingTaskDto>? _table;
    private string _assignedTo = "";
    private PickingTaskStatus? _status = PickingTaskStatus.Assigned;
    private bool _onlyMine;
    private string? _gapMessage;

    private async Task<TableData<PickingTaskDto>> LoadAsync(TableState state, CancellationToken ct)
    {
        var effectiveAssignedTo = _onlyMine ? TokenStore.UserId : (string.IsNullOrWhiteSpace(_assignedTo) ? null : _assignedTo);
        var result = await Api.Outbound.ListPickingTasksAsync(state.Page + 1, state.PageSize, effectiveAssignedTo, _status, waveId: null, ct);
        if (!result.Success) { _gapMessage = result.ErrorMessage; return new TableData<PickingTaskDto> { Items = Array.Empty<PickingTaskDto>(), TotalItems = 0 }; }
        _gapMessage = null;
        return new TableData<PickingTaskDto> { Items = result.Value!.Items, TotalItems = result.Value!.TotalCount };
    }

    private void ApplyFilter() => _table?.ReloadServerData();
    private void ResetFilter() { _assignedTo = ""; _status = PickingTaskStatus.Assigned; _onlyMine = false; _table?.ReloadServerData(); }

    private async Task OpenComplete(PickingTaskDto task)
    {
        var parameters = new DialogParameters { [nameof(CompletePickingDialog.Existing)] = task };
        var dialog = await DialogService.ShowAsync<CompletePickingDialog>("Complete Picking", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: true }) _table?.ReloadServerData();
    }

    private static Color TaskColor(string s) => s switch
    { "Assigned" => Color.Warning, "Completed" => Color.Success, _ => Color.Default };
}
