@page "/reporting/stock-on-hand"
@inject WmsApiClient Api
@inject WarehouseNameResolver WarehouseNames

<PageTitle>Stock on Hand</PageTitle>
<PageHeader Title="Stock on Hand" />

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudSelect T="Guid?" @bind-Value="_warehouseId" Label="Warehouse" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:200px;">
            @foreach (var w in _warehouses)
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)w.WarehouseId)">@w.Name</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_sku" Label="SKU" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:200px;" />
        <MudButton OnClick="ApplyFilter" Variant="Variant.Outlined">Apply</MudButton>
        <MudButton OnClick="ResetFilter" Variant="Variant.Text">Reset</MudButton>
    </MudStack>
</MudPaper>

<MudTable T="StockOnHandRow" ServerData="LoadAsync" Dense="true" Hover="true" Striped="true" @ref="_table">
    <HeaderContent><MudTh>Warehouse</MudTh><MudTh>SKU</MudTh><MudTh>Batch</MudTh><MudTh>Qty On Hand</MudTh></HeaderContent>
    <RowTemplate>
        <MudTd>@WarehouseNames.Resolve(context.WarehouseId)</MudTd><MudTd>@context.Sku</MudTd><MudTd>@context.Batch</MudTd><MudTd>@context.QtyOnHand</MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
    <NoRecordsContent><MudAlert Severity="Severity.Info" Class="ma-3">Tidak ada stock.</MudAlert></NoRecordsContent>
</MudTable>

@code {
    private MudTable<StockOnHandRow>? _table;
    private Guid? _warehouseId;
    private IReadOnlyList<WarehouseDto> _warehouses = [];
    private string _sku = "";
    private string? _error;

    // muat warehouse untuk dropdown filter (gantikan free-text GUID — lookup, bukan ketik id)
    protected override async Task OnInitializedAsync()
    {
        var warehouses = await Api.MasterData.ListWarehousesAsync(1, 100, isActive: true);
        if (warehouses.Success)
            _warehouses = warehouses.Value!.Items;
    }

    private async Task<TableData<StockOnHandRow>> LoadAsync(TableState state, CancellationToken ct)
    {
        await WarehouseNames.EnsureLoadedAsync(ct); // peta Id→Name siap sebelum RowTemplate render
        var result = await Api.Reporting.ListStockOnHandAsync(state.Page + 1, state.PageSize,
            string.IsNullOrWhiteSpace(_sku) ? null : _sku,
            _warehouseId?.ToString(), ct);
        if (!result.Success) { _error = result.ErrorMessage; return new TableData<StockOnHandRow> { Items = Array.Empty<StockOnHandRow>(), TotalItems = 0 }; }
        _error = null;
        return new TableData<StockOnHandRow> { Items = result.Value!.Items, TotalItems = result.Value!.TotalCount };
    }

    private void ApplyFilter() => _table?.ReloadServerData();
    private void ResetFilter() { _warehouseId = null; _sku = ""; _table?.ReloadServerData(); }
}
