@inherits LayoutComponentBase
@implements IDisposable
@inject TokenStore TokenStore
@inject NavigationManager Nav
@inject ProtectedLocalStorage Storage

<MudThemeProvider Theme="_softTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">TomSandboxWMS</MudText>
        <MudSpacer />
        <NotificationBell />
        @if (TokenStore.IsAuthenticated)
        {
            <MudText Class="mr-3">@TokenStore.Username</MudText>
            <MudButton Color="Color.Inherit" OnClick="Logout">Logout</MudButton>
        }
        else
        {
            <MudButton Href="/" Color="Color.Inherit">Login</MudButton>
        }
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="1"
               Variant="DrawerVariant.Mini" OpenMiniOnHover="true">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-6">
            @if (TokenStore.Hydrated)
            {
                @Body
            }
            else
            {
                @* tunggu hydrate dari ProtectedLocalStorage (sekali per circuit) sebelum page init *@
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    // ── Soft theme (Teal) ────────────────────────────────────────────────────
    // Palet low-saturation + sudut membulat + shadow lembut. Ganti nilai Primary
    // di sini untuk hue lain: Periwinkle #6D78DC, Rose #D67D9F, Sage #7FA876.
    private readonly MudTheme _softTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary          = "#3FA89C",
            PrimaryDarken    = "#2C857B",
            PrimaryLighten   = "#E0F1EF",
            Secondary        = "#8A5FB8",
            Tertiary         = "#3FA89C",
            Success          = "#2F8F6B",
            Info             = "#3B7EB8",
            Warning          = "#B5882F",
            Error            = "#C25B5B",
            Background       = "#F4F4FA",
            BackgroundGray   = "#EFEFF6",
            Surface          = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            AppbarText       = "#3A3A4D",
            DrawerBackground = "#FFFFFF",
            DrawerText       = "#5C5C72",
            DrawerIcon       = "#9A9AB2",
            TextPrimary      = "#34344A",
            TextSecondary    = "#8A8AA0",
            ActionDefault    = "#9A9AB2",
            Divider          = "rgba(120,120,160,0.12)",
            TableLines       = "rgba(120,120,160,0.10)",
            LinesDefault     = "rgba(120,120,160,0.18)",
            HoverOpacity     = 0.06,
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "12px",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography { FontFamily = new[] { "Roboto", "system-ui", "sans-serif" } },
            H4      = new H4Typography      { FontWeight = "500" },
            H5      = new H5Typography      { FontWeight = "500" },
            H6      = new H6Typography      { FontWeight = "500" },
        },
    };
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override void OnInitialized() => TokenStore.OnChange += StateHasChanged;

    // hydrate sekali, di interactive render pertama (JS interop ProtectedLocalStorage tersedia, HttpContext tak dibutuhkan)
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || TokenStore.Hydrated)
            return;

        var token = await Storage.GetAsync<string>("wms.access");
        if (token.Success && !string.IsNullOrEmpty(token.Value))
        {
            var username = await Storage.GetAsync<string>("wms.username");
            var userId = await Storage.GetAsync<string>("wms.userId");
            TokenStore.SetSession(
                token.Value,
                username.Value ?? string.Empty,
                string.IsNullOrEmpty(userId.Value) ? null : userId.Value);
        }
        TokenStore.MarkHydrated(); // selalu set — agar @Body render walau tanpa token (guard internal page tetap jalan)
    }

    private async Task Logout()
    {
        TokenStore.Clear();
        await Storage.DeleteAsync("wms.access");
        await Storage.DeleteAsync("wms.username");
        await Storage.DeleteAsync("wms.userId");
        Nav.NavigateTo("/");
    }

    public void Dispose() => TokenStore.OnChange -= StateHasChanged;
}
