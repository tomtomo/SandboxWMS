@inject WmsApiClient Api
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <div style="min-width:480px;">
        <MudAlert Severity="Severity.Warning" Class="mb-3">Hold menolak seluruh GR (terminal). Tidak ada event/stock. Tak bisa di-undo.</MudAlert>
        <EditForm EditContext="_editContext" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <MudTextField @bind-Value="_form.Reason" Label="Reason" Required="true" Lines="4" Variant="Variant.Outlined" Class="mb-3" />
            <ValidationSummary />
        </EditForm>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_busy">Batal</MudButton>
        <MudButton OnClick="HandleSubmit" Color="Color.Error" Variant="Variant.Filled" Disabled="_busy">@(_busy ? "Holding..." : "Hold GR")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter, EditorRequired] public Guid GoodsReceiptId { get; set; }
    private HoldGoodsReceiptForm _form = new();
    private EditContext _editContext = default!;
    private bool _busy;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_form);
    }

    private async Task HandleSubmit()
    {
        if (!_editContext.Validate()) return;
        _busy = true;
        var result = await Api.Inbound.HoldAsync(GoodsReceiptId, _form);
        _busy = false;
        if (result.Success) { Snackbar.Add("GR di-hold.", Severity.Warning); Dialog.Close(DialogResult.Ok(true)); }
        else Snackbar.Add($"Gagal: {result.ErrorMessage}", Severity.Error);
    }

    private void Cancel() => Dialog.Cancel();
}
