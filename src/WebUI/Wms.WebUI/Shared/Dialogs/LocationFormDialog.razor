@inject WmsApiClient Api
@inject ISnackbar Snackbar

@* Create Location (M1: create-only). Warehouse dipilih via MudSelect dari ListWarehouses — gantikan
   paste-GUID manual (lookup, bukan input id mentah). Type = MudSelect enum; Code = free-text. *@
<MudDialog>
    <DialogContent>
        <EditForm EditContext="_editContext" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            @if (_warehouses.Count == 0)
            {
                <MudAlert Severity="Severity.Warning" Class="mb-2">
                    Belum ada warehouse. Buat dulu di Master Data → Warehouses.
                </MudAlert>
            }
            else
            {
                <MudSelect T="Guid?" @bind-Value="_form.WarehouseId" Label="Warehouse" Required="true"
                           Variant="Variant.Outlined" Class="mb-3">
                    @foreach (var w in _warehouses)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)w.WarehouseId)">@w.Name</MudSelectItem>
                    }
                </MudSelect>
            }
            <MudSelect T="LocationType?" @bind-Value="_form.Type" Label="Type" Required="true" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var t in Enum.GetValues<LocationType>())
                {
                    <MudSelectItem T="LocationType?" Value="@((LocationType?)t)">@t</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_form.Code" Label="Code (e.g. RACK-A01-03)" Required="true" Variant="Variant.Outlined" Class="mb-3" />
            <ValidationSummary />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_busy">Batal</MudButton>
        <MudButton OnClick="HandleSubmit" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@(_busy || _form.WarehouseId is null)">@(_busy ? "Menyimpan..." : "Simpan")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    private LocationForm _form = new();
    private EditContext _editContext = default!;
    private IReadOnlyList<WarehouseDto> _warehouses = [];
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        _editContext = new EditContext(_form); // sebelum await → siap untuk first render EditForm
        var result = await Api.MasterData.ListWarehousesAsync(1, 100, isActive: true);
        if (result.Success)
            _warehouses = result.Value!.Items;
    }

    private async Task HandleSubmit()
    {
        if (_form.WarehouseId is null)
            return;
        if (!_editContext.Validate())
            return;

        _busy = true;
        var result = await Api.MasterData.CreateLocationAsync(_form);
        _busy = false;
        if (result.Success)
        {
            Snackbar.Add("Location dibuat.", Severity.Success);
            Dialog.Close(DialogResult.Ok(true));
        }
        else
        {
            Snackbar.Add($"Gagal: {result.ErrorMessage}", Severity.Error);
        }
    }

    private void Cancel() => Dialog.Cancel();
}
