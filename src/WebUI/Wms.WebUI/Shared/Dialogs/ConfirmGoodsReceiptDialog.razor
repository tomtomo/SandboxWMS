@inject WmsApiClient Api
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <div style="min-width:480px;">
        <MudText Typo="Typo.h6" Class="mb-3">Confirm Goods Receipt</MudText>
        @if (_unresolved.Count > 0)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-3">Masih ada @_unresolved.Count discrepancy belum resolved. Resolve dulu.</MudAlert>
            <MudList T="string" Dense="true">
                @foreach (var d in _unresolved)
                {
                    <MudListItem T="string">@d.Sku — @d.Type (qty @d.Qty)</MudListItem>
                }
            </MudList>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Class="mb-3">
                Semua discrepancy resolved. Confirm akan set state <b>Confirmed</b> + emit <code>GRConfirmed</code> ke Inventory (auto-create Stock + PutawayTask).
            </MudAlert>
            <MudText Typo="Typo.body2">Lanjut?</MudText>
        }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_busy">Batal</MudButton>
        <MudButton OnClick="HandleSubmit" Color="Color.Success" Variant="Variant.Filled" Disabled="@(_busy || _unresolved.Count > 0)">@(_busy ? "Confirming..." : "Confirm GR")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter, EditorRequired] public Guid GoodsReceiptId { get; set; }
    [Parameter, EditorRequired] public IReadOnlyList<DiscrepancyDto> Discrepancies { get; set; } = Array.Empty<DiscrepancyDto>();

    private List<DiscrepancyDto> _unresolved = new();
    private bool _busy;

    protected override void OnInitialized()
        => _unresolved = Discrepancies.Where(d => string.IsNullOrEmpty(d.ResolutionAction)).ToList();

    private async Task HandleSubmit()
    {
        _busy = true;
        var result = await Api.Inbound.ConfirmAsync(GoodsReceiptId);
        _busy = false;
        if (result.Success) { Snackbar.Add("GR di-confirm. GRConfirmed emitted.", Severity.Success); Dialog.Close(DialogResult.Ok(true)); }
        else Snackbar.Add($"Gagal: {result.ErrorMessage}", Severity.Error);
    }

    private void Cancel() => Dialog.Cancel();
}
