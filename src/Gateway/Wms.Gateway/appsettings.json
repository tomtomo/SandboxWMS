{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "//": "YARP routing REST UI/klien -> tiap service (ADR-0006, Task 3). Destination 'http://<service>' = nama resource Aspire, di-resolve service-discovery resolver. NO transcoding: tiap service expose REST sendiri; path di-forward apa adanya (tanpa transform). Authorization & X-Correlation-ID diteruskan YARP by default.",
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/{**catch-all}" }
      },
      "inbound-goods-receipts": {
        "ClusterId": "inbound",
        "Match": { "Path": "/goods-receipts/{**catch-all}" }
      },
      "inventory-putaway": {
        "ClusterId": "inventory",
        "Match": { "Path": "/putaway-tasks/{**catch-all}" }
      },
      "outbound-waves": {
        "ClusterId": "outbound",
        "Match": { "Path": "/waves/{**catch-all}" }
      },
      "outbound-orders": {
        "ClusterId": "outbound",
        "Match": { "Path": "/outbound-orders/{**catch-all}" }
      },
      "outbound-picking": {
        "ClusterId": "outbound",
        "Match": { "Path": "/picking-tasks/{**catch-all}" }
      },
      "masterdata-warehouses": {
        "ClusterId": "masterdata",
        "Match": { "Path": "/warehouses/{**catch-all}" }
      },
      "masterdata-products": {
        "ClusterId": "masterdata",
        "Match": { "Path": "/products/{**catch-all}" }
      },
      "masterdata-locations": {
        "ClusterId": "masterdata",
        "Match": { "Path": "/locations/{**catch-all}" }
      },
      "reporting-reports": {
        "ClusterId": "reporting",
        "Match": { "Path": "/reports/{**catch-all}" }
      },
      "notification": {
        "ClusterId": "notification",
        "Match": { "Path": "/notifications/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth": { "Destinations": { "auth": { "Address": "http://auth" } } },
      "inbound": { "Destinations": { "inbound": { "Address": "http://inbound" } } },
      "inventory": { "Destinations": { "inventory": { "Address": "http://inventory" } } },
      "outbound": { "Destinations": { "outbound": { "Address": "http://outbound" } } },
      "masterdata": { "Destinations": { "masterdata": { "Address": "http://masterdata" } } },
      "reporting": { "Destinations": { "reporting": { "Address": "http://reporting" } } },
      "notification": { "Destinations": { "notification": { "Address": "http://notification" } } }
    }
  }
}
